# ─── Ports ───────────────────────────────────────────────────────────────────
MS_AUTH_PORT=3001
MFE_AUTH_PORT=4001
SHELL_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── AWS / Ministack (LocalStack) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# ─── RDS (credenciais partilhadas; porta 5432) ─────────────────────────────────
# plus-ms-auth no docker-compose usa DB_HOST=ministack (rede interna).
# MS com npm run dev na máquina: Postgres exposto no host → DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=plus
DB_PASSWORD=plus_secret
DB_NAME=plus_auth

# ─── MFE Auth - API Gateway URL ────────────────────────────────────────────────
# Após o provisionamento, obtenha o gateway URL com:
# cd terraform && terraform output -raw gateway_url
# ou, quando usar LocalStack/AWS CLI local, use:
# awslocal apigateway get-rest-apis | jq -r '.items[0].id'
VITE_MS_AUTH_URL=http://localhost:4566/restapis/placeholder-api-id/v1/_user_request_
