# ─── Ports ───────────────────────────────────────────────────────────────────
MS_AUTH_PORT=3001
MFE_AUTH_PORT=4001
SHELL_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── AWS / Ministack (LocalStack) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# ─── RDS (credenciais alinhadas com o Terraform) ───────────────────────────────
# O plus-ms-auth lê DB_HOST/DB_PORT de terraform/rds.env (gerado por scripts/write-rds-env após apply).
# Para npm run dev no PC: use os mesmos valores (terraform output -raw rds_address / rds_port).
DB_HOST=localhost
DB_PORT=5432
DB_USER=plus
DB_PASSWORD=plus_secret
DB_NAME=plus_auth

# ─── MFE → API Gateway (URL base para o build do Vite) ─────────────────────────
# O "make setup" atualiza esta linha automaticamente a partir do Terraform.
# Se correr só "docker compose up" sem esse passo, pode definir manualmente:
#   terraform -chdir=terraform output -raw gateway_url
VITE_MS_AUTH_URL=http://localhost:4566/restapis/placeholder-api-id/v1/_user_request_
